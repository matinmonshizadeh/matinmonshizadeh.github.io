---
import { getEntry } from 'astro:content';
import deerImg from '../assets/hero/deer.png';

const site = await getEntry('site', 'config');
const { name } = site!.data;

const navLinks = [
  { href: '/',           label: 'Home'       },
  { href: '/about',      label: 'About'      },
  { href: '/experience', label: 'Experience' },
  { href: '/projects',   label: 'Projects'   },
  { href: '/contact',    label: 'Contact'    },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 h-16 border-b border-bg-border bg-bg-base/80 backdrop-blur-md transition-shadow duration-200"
>
  <nav
    class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 h-full flex items-center justify-between"
    aria-label="Main navigation"
  >
    <!-- Logo / home link -->
    <a
      href="/"
      class="nav-home-link group flex items-center gap-2.5 rounded-sm"
    >
      <div class="nav-deer-anim" aria-hidden="true">
        <div class="nav-deer-clip" style={`background-image: url('${deerImg.src}')`}></div>
      </div>
      <span class="font-heading font-semibold text-fg-primary group-hover:text-accent transition-colors duration-150">
        {name}
      </span>
    </a>

    <!-- Desktop links (≥768px) — skip Home since logo covers it -->
    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0" role="list">
      {navLinks.filter(l => l.href !== '/').map(link => (
        <li>
          <a
            href={link.href}
            class={`font-sans text-sm transition-colors duration-150 rounded-sm ${
              isActive(link.href) ? 'text-accent' : 'text-fg-secondary hover:text-fg-primary'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Hamburger toggle (<768px) -->
    <button
      id="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
      class="md:hidden flex items-center justify-center w-11 h-11 text-fg-primary hover:text-accent transition-colors duration-150 rounded-sm"
    >
      <svg id="icon-open" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="2" y1="5"  x2="20" y2="5"/>
        <line x1="2" y1="11" x2="20" y2="11"/>
        <line x1="2" y1="17" x2="20" y2="17"/>
      </svg>
      <svg id="icon-close" class="hidden" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="4" y1="4" x2="18" y2="18"/>
        <line x1="18" y1="4" x2="4" y2="18"/>
      </svg>
    </button>
  </nav>
</header>

<!-- ── Glass mobile menu ── -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="fixed inset-0 top-16 z-40 flex flex-col items-center justify-center"
  style="
    background: linear-gradient(135deg, rgba(10,17,24,0.65) 0%, rgba(15,26,34,0.75) 100%);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-top: 1px solid rgba(63,224,197,0.12);
  "
>
  <!-- Ambient glow: top-right -->
  <div
    class="menu-glow-orb absolute pointer-events-none"
    style="
      top: -60px; right: -60px;
      width: 400px; height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(63,224,197,0.08) 0%, transparent 70%);
    "
    aria-hidden="true"
  ></div>

  <!-- Ambient glow: bottom-left -->
  <div
    class="menu-glow-orb absolute pointer-events-none"
    style="
      bottom: -40px; left: -40px;
      width: 300px; height: 300px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(63,224,197,0.07) 0%, transparent 70%);
      animation-delay: -3s;
    "
    aria-hidden="true"
  ></div>

  <!-- Links -->
  <ul class="relative flex flex-col items-center gap-8 list-none m-0 p-0" role="list">
    {navLinks.map(link => (
      <li class="menu-link-item">
        <a
          href={link.href}
          class={`flex items-center font-heading text-3xl font-medium transition-all duration-200 rounded-sm
            ${isActive(link.href)
              ? 'text-accent menu-link-active'
              : 'text-fg-primary hover:text-accent hover:[text-shadow:0_0_20px_rgba(63,224,197,0.4)]'
            }`}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</div>

<div class="h-16" aria-hidden="true"></div>

<script>
  const toggle    = document.getElementById('nav-toggle')!;
  const menu      = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;
  const nav       = document.getElementById('site-nav')!;

  if (!toggle || !menu || !iconOpen || !iconClose || !nav) {
    console.error('Nav: required elements not found');
  } else {
    let isOpen = false;
    const FOCUSABLE = 'a[href], button:not([disabled])';

    function openMenu() {
      isOpen = true;
      menu.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close navigation menu');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      (menu.querySelector<HTMLElement>(FOCUSABLE))?.focus();
    }

    function closeMenu() {
      isOpen = false;
      menu.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open navigation menu');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      document.body.style.overflow = '';
      toggle.focus();
    }

    toggle.addEventListener('click', () => {
      isOpen ? closeMenu() : openMenu();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });

    menu.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const items = Array.from(menu.querySelectorAll<HTMLElement>(FOCUSABLE));
      const first = items[0];
      const last  = items[items.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

    window.addEventListener('scroll', () => {
      nav.classList.toggle('shadow-lg', window.scrollY > 10);
    }, { passive: true });
  }
</script>
