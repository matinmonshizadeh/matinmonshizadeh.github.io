---
import { getEntry } from 'astro:content';

const site = await getEntry('site', 'config');
const { name, cv } = site!.data;

const navLinks = [
  { href: '/projects', label: 'Projects' },
  { href: '/about',    label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 h-16 border-b border-bg-border bg-bg-base/80 backdrop-blur-md transition-shadow duration-200"
>
  <nav
    class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 h-full flex items-center justify-between"
    aria-label="Main navigation"
  >
    <!-- Logo / home link -->
    <a
      href="/"
      class="font-heading font-semibold text-fg-primary hover:text-accent transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
    >
      {name}
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`font-sans text-sm transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm ${
              currentPath.startsWith(link.href)
                ? 'text-accent'
                : 'text-fg-secondary hover:text-fg-primary'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={cv}
          download
          class="font-sans text-sm text-fg-secondary hover:text-fg-primary transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
        >
          CV
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
      class="md:hidden flex items-center justify-center w-11 h-11 text-fg-primary hover:text-accent transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
    >
      <svg id="icon-open" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="2" y1="5"  x2="20" y2="5"/>
        <line x1="2" y1="11" x2="20" y2="11"/>
        <line x1="2" y1="17" x2="20" y2="17"/>
      </svg>
      <svg id="icon-close" class="hidden" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="4" y1="4" x2="18" y2="18"/>
        <line x1="18" y1="4" x2="4" y2="18"/>
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile fullscreen overlay -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="hidden fixed inset-0 top-16 bg-bg-base z-40 flex-col items-center justify-center gap-10"
>
  <ul class="flex flex-col items-center gap-8 list-none m-0 p-0" role="list">
    {navLinks.map(link => (
      <li>
        <a
          href={link.href}
          class="font-heading text-2xl font-semibold text-fg-primary hover:text-accent transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm"
        >
          {link.label}
        </a>
      </li>
    ))}
    <li>
      <a
        href={cv}
        download
        class="font-heading text-2xl font-semibold text-fg-primary hover:text-accent transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm"
      >
        CV
      </a>
    </li>
  </ul>
</div>

<!-- Height spacer so content isn't hidden under fixed nav -->
<div class="h-16" aria-hidden="true"></div>

<script>
  const toggle   = document.getElementById('nav-toggle')!;
  const menu     = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;
  const nav       = document.getElementById('site-nav')!;

  const FOCUSABLE = 'a[href], button:not([disabled])';

  function openMenu() {
    menu.classList.remove('hidden');
    menu.classList.add('flex');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close navigation menu');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    (menu.querySelector<HTMLElement>(FOCUSABLE))?.focus();
  }

  function closeMenu() {
    menu.classList.add('hidden');
    menu.classList.remove('flex');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    document.body.style.overflow = '';
    toggle.focus();
  }

  toggle.addEventListener('click', () => {
    toggle.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') closeMenu();
  });

  // Focus trap inside mobile menu
  menu.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const items = Array.from(menu.querySelectorAll<HTMLElement>(FOCUSABLE));
    const first = items[0];
    const last  = items[items.length - 1];
    if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
  });

  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

  // Subtle shadow on scroll
  window.addEventListener('scroll', () => {
    nav.classList.toggle('shadow-lg', window.scrollY > 10);
  }, { passive: true });
</script>
