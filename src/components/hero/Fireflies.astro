  { x: 20, y: 42, size: 4, opacity: 0.90, dur: 6.5, delay: -4.3, bdur: 3.5, bdelay: -0.6,  dx1:   6, dy1:  10, dx2: -12, dy2: -8,  dx3:  10, dy3:  12 },
  { x: 28, y: 78, size: 2, opacity: 0.65, dur: 9.1, delay: -1.5, bdur: 2.4, bdelay: -2.1,  dx1: -14, dy1:   4, dx2:   8, dy2: -16, dx3:  -6, dy3:   6 },
  { x: 35, y: 60, size: 3, opacity: 0.80, dur: 7.8, delay: -5.7, bdur: 3.8, bdelay: -1.7,  dx1:  10, dy1:  -6, dx2: -16, dy2:  10, dx3:  12, dy3:  -8 },
