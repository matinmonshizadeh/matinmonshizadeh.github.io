---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import forestImg from '../../assets/hero/forest.png';
import Fireflies from './Fireflies.astro';
import FallingLeaves from './FallingLeaves.astro';
import MossGlow from './MossGlow.astro';

const site = await getEntry('site', 'config');
const { name, role, tagline, cv } = site!.data;

const rays = [
  { x: 30, h: 65, angle: '-8deg'  },
  { x: 38, h: 55, angle:  '2deg'  },
  { x: 48, h: 70, angle: '-3deg'  },
  { x: 60, h: 60, angle:  '6deg'  },
  { x: 70, h: 50, angle: '-12deg' },
];
---

<section
  class="relative min-h-[calc(100vh-4rem)] flex items-center overflow-hidden"
  aria-label="Introduction"
>
  <!-- Layer 0: Forest base image (full-bleed) -->
  <div class="absolute inset-0 hero-forest-bg" style={`background-image:url('${forestImg.src}')`} aria-hidden="true"></div>

  <!-- Layer 1: Dark left-to-right gradient overlay — keeps text legible -->
  <div class="absolute inset-0 hero-forest-overlay" aria-hidden="true"></div>

  <!-- Layer 2: Moss glow orbs (forest floor bioluminescence) -->
  <MossGlow />

  <!-- Layer 3: Fog sweep bands -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute inset-0 fog-layer-1"></div>
    <div class="absolute inset-0 fog-layer-2"></div>
  </div>

  <!-- Layer 4: Crepuscular light rays -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden hidden md:block" aria-hidden="true">
    {rays.map((r, i) => (
      <div
        class="light-ray absolute top-0 pointer-events-none"
        style={[
          `left:${r.x}%`,
          `height:${r.h}%`,
          `--ray-angle:${r.angle}`,
          `animation-delay:${-i * 1.3}s`,
        ].join(';')}
      />
    ))}
  </div>

  <!-- Layer 5: Deer glow halo (right side, where deer lives in the image) -->
  <div
    class="deer-halo absolute pointer-events-none hidden md:block"
    style="right:18%;top:35%;width:220px;height:220px;transform:translate(50%,-50%)"
    aria-hidden="true"
  ></div>

  <!-- Layer 6: Fireflies (all sizes) -->
  <Fireflies />

  <!-- Layer 7: Falling leaves -->
  <FallingLeaves />

  <!-- Layer 8: Bottom fade — blends hero into the page background -->
  <div class="absolute bottom-0 left-0 right-0 h-40 hero-forest-bottom-fade pointer-events-none" aria-hidden="true"></div>

  <!-- Layer 9: Vignette -->
  <div class="absolute inset-0 hero-vignette pointer-events-none" aria-hidden="true"></div>

  <!-- Layer 10: Text content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 py-12 md:py-20 lg:py-28 w-full">
    <div class="max-w-2xl">
      <p class="font-mono text-accent text-sm mb-4 tracking-wide">
        {role}
      </p>

      <h1 class="font-heading font-bold text-fg-primary text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-tight mb-6 text-glow">
        {name}
      </h1>

      <p class="font-sans text-fg-secondary text-lg md:text-xl max-w-xl mb-10 leading-relaxed">
        {tagline}
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="/projects"
          class="inline-flex items-center justify-center min-h-[44px] px-6 py-2.5 bg-accent text-bg-base font-sans font-medium text-sm rounded hover:bg-accent-light hover:shadow-[0_0_20px_rgba(63,224,197,0.4)] transition-all duration-150"
        >
          View Projects
        </a>
        <a
          href={cv}
          download
          class="inline-flex items-center justify-center min-h-[44px] px-6 py-2.5 border border-accent text-accent font-sans font-medium text-sm rounded hover:bg-accent hover:text-bg-base hover:shadow-[0_0_20px_rgba(63,224,197,0.3)] transition-all duration-150"
        >
          Download CV
        </a>
      </div>
    </div>
  </div>
</section>
