---
interface Props {
  name:   string;
  skills: string[];
}

const { name, skills } = Astro.props;
---

<div>
  <h3 class="font-heading font-semibold text-fg-primary text-sm uppercase tracking-wider mb-3">
    {name}
  </h3>
  <ul class="flex flex-wrap gap-2 list-none m-0 p-0" role="list">
    {skills.map(skill => (
      <li>
        <span class="font-mono text-xs text-accent bg-bg-elevated border border-bg-border px-3 py-1.5 rounded">
          {skill}
        </span>
      </li>
    ))}
  </ul>
</div>
