---
interface Props {
  slug:        string;
  title:       string;
  cover:       string;
  description: string;
  tags:        string[];
  date:        Date;
  links?:      { play?: string };
}

const { slug, title, cover, description, tags, date, links } = Astro.props;
const year = date.getFullYear();
---

<article class="group flex flex-col bg-bg-elevated border border-bg-border rounded-lg overflow-hidden transition-all duration-200 hover:border-accent/40 hover:shadow-[0_0_20px_rgba(63,224,197,0.15)] focus-within:border-accent/40">
  <!-- Cover — explicit 16:9 -->
  <a
    href={`/projects/${slug}`}
    class="block w-full overflow-hidden"
    style="aspect-ratio: 16/9;"
    tabindex="-1"
    aria-hidden="true"
  >
    <img
      src={cover}
      alt=""
      width="800"
      height="450"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
    />
  </a>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <!-- min-w-0 on the flex row prevents long titles from overflowing -->
    <div class="flex items-start justify-between gap-2 min-w-0">
      <h3 class="font-heading font-semibold text-fg-primary text-base leading-snug min-w-0">
        <a
          href={`/projects/${slug}`}
          class="hover:text-accent transition-colors duration-150 rounded-sm"
        >
          {title}
        </a>
      </h3>
      <span class="font-mono text-fg-secondary text-xs shrink-0 mt-0.5">{year}</span>
    </div>

    <p class="font-sans text-fg-secondary text-sm leading-relaxed line-clamp-2">
      {description}
    </p>

    <ul class="flex flex-wrap gap-2 list-none m-0 p-0 mt-auto pt-1" role="list">
      {tags.slice(0, 4).map(tag => (
        <li>
          <span class="font-mono text-xs text-fg-secondary bg-bg-base border border-bg-border px-2 py-0.5 rounded">
            {tag}
          </span>
        </li>
      ))}
    </ul>

    {links?.play && (
      <a
        href={links.play}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex items-center justify-center gap-2 w-full min-h-[44px] px-4 py-2 border border-accent text-accent font-sans text-sm font-medium rounded hover:bg-accent hover:text-bg-base transition-all duration-150"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <polygon points="5,3 19,12 5,21"/>
        </svg>
        Play
      </a>
    )}
  </div>
</article>
