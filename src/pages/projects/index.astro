---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { getCollection, getEntry } from 'astro:content';

const allProjects  = await getCollection('projects');
const university   = allProjects.filter(p => p.data.type === 'university');
const independent  = allProjects.filter(p => p.data.type === 'independent');
const games        = allProjects.filter(p => p.data.type === 'game');

const site = await getEntry('site', 'config');
const { name, projects_page_desc, university_section_desc, independent_section_desc, games_section_desc, projects_page_meta_desc } = site!.data;
---

<BaseLayout
  title={`Projects — ${name}`}
  description={projects_page_meta_desc ?? 'University research projects in computer vision and graphics, plus interactive browser games.'}
>

  <!-- Page header -->
  <div class="border-b border-bg-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 py-12 md:py-16">
      <h1 class="font-heading font-bold text-fg-primary text-3xl md:text-4xl lg:text-5xl mb-3">
        Projects
      </h1>
      <p class="font-sans text-fg-secondary text-base md:text-lg max-w-xl">
        {projects_page_desc ?? "Research, coursework, and side projects across computer vision, image processing, and graphics."}
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24">

    <!-- University projects -->
    {university.length > 0 && (
      <section class="py-12 md:py-20" aria-labelledby="university-heading">
        <div class="mb-8 md:mb-10" data-animate>
          <h2 id="university-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl mb-2">
            University Projects
          </h2>
          <p class="font-sans text-fg-secondary text-sm md:text-base">
            {university_section_desc ?? "Research and coursework from my master's programme."}
          </p>
        </div>
        <div data-animate>
          <ProjectGrid projects={university} />
        </div>
      </section>
    )}

    <!-- Divider: university → independent -->
    {university.length > 0 && (
      <hr class="border-bg-border" />
    )}

    <!-- Independent projects (always shown) -->
    <section class="py-12 md:py-20" aria-labelledby="independent-heading">
      <div class="mb-8 md:mb-10" data-animate>
        <h2 id="independent-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl mb-2">
          Independent Projects
        </h2>
        <p class="font-sans text-fg-secondary text-sm md:text-base">
          {independent_section_desc ?? "Side projects, research explorations, and experiments I built on my own time."}
        </p>
      </div>
      {independent.length > 0 ? (
        <div data-animate>
          <ProjectGrid projects={independent} />
        </div>
      ) : (
        <p class="font-sans text-fg-tertiary text-sm" data-animate>More projects coming soon.</p>
      )}
    </section>

    <!-- Divider: independent → games -->
    {games.length > 0 && (
      <hr class="border-bg-border" />
    )}

    <!-- Games -->
    {games.length > 0 && (
      <section class="py-12 md:py-20" aria-labelledby="games-heading">
        <div class="mb-8 md:mb-10" data-animate>
          <h2 id="games-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl mb-2">
            Fun Games
          </h2>
          <p class="font-sans text-fg-secondary text-sm md:text-base">
            {games_section_desc ?? "Interactive browser experiments and playable graphics demos."}
          </p>
        </div>
        <div data-animate>
          <ProjectGrid projects={games} />
        </div>
      </section>
    )}

  </div>
</BaseLayout>
