---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const sorted   = [...projects].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((project, i) => ({
    params: { slug: project.id },
    props:  {
      project,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

const { project, prev, next } = Astro.props;
const { title, cover, tags, stack, date, description, links } = project.data;
const { Content } = await render(project);

const site = await getEntry('site', 'config');
const { name } = site!.data;

const formattedDate = date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long' });
---

<BaseLayout title={`${title} — ${name}`} description={description}>

  <!-- Cover -->
  <div class="w-full aspect-video max-h-[520px] overflow-hidden bg-bg-elevated">
    <img
      src={cover}
      alt={`${title} cover image`}
      width="1200"
      height="675"
      class="w-full h-full object-cover"
    />
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 py-12 md:py-16">

    <!-- Title + meta -->
    <header class="mb-10">
      <h1 class="font-heading font-bold text-fg-primary text-3xl md:text-4xl lg:text-5xl mb-4 leading-tight">
        {title}
      </h1>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-4">
        <time
          datetime={date.toISOString()}
          class="font-mono text-fg-secondary text-sm"
        >
          {formattedDate}
        </time>
      </div>

      <!-- Tags -->
      <ul class="flex flex-wrap gap-2 list-none m-0 p-0" role="list" aria-label="Topics">
        {tags.map(tag => (
          <li>
            <span class="font-mono text-xs text-accent bg-bg-elevated border border-bg-border px-2.5 py-1 rounded">
              {tag}
            </span>
          </li>
        ))}
      </ul>
    </header>

    <!-- Markdown body -->
    <div class="prose-content mb-12">
      <Content />
    </div>

    <!-- Tech stack -->
    <section class="mb-10" aria-labelledby="stack-heading">
      <h2 id="stack-heading" class="font-heading font-semibold text-fg-primary text-xl mb-4">
        Tech Stack
      </h2>
      <ul class="flex flex-wrap gap-2 list-none m-0 p-0" role="list">
        {stack.map(item => (
          <li>
            <span class="font-mono text-sm text-fg-secondary bg-bg-elevated border border-bg-border px-3 py-1.5 rounded">
              {item}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Links -->
    {links && Object.values(links).some(Boolean) && (
      <section class="mb-12 flex flex-wrap gap-3" aria-label="Project links">
        {links.github && (
          <a
            href={links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 min-h-[44px] px-5 py-2 border border-bg-border text-fg-secondary text-sm font-sans rounded hover:border-accent hover:text-accent transition-all duration-150"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
        )}
        {links.demo && (
          <a
            href={links.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 min-h-[44px] px-5 py-2 border border-bg-border text-fg-secondary text-sm font-sans rounded hover:border-accent hover:text-accent transition-all duration-150"
          >
            Live Demo
          </a>
        )}
        {links.paper && (
          <a
            href={links.paper}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 min-h-[44px] px-5 py-2 border border-bg-border text-fg-secondary text-sm font-sans rounded hover:border-accent hover:text-accent transition-all duration-150"
          >
            Paper
          </a>
        )}
        {links.play && (
          <a
            href={links.play}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 min-h-[44px] px-5 py-2 bg-accent text-bg-base text-sm font-sans font-medium rounded hover:bg-accent-light transition-colors duration-150"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <polygon points="5,3 19,12 5,21"/>
            </svg>
            Play
          </a>
        )}
      </section>
    )}

    <!-- Prev / Next navigation -->
    <nav aria-label="Project navigation" class="border-t border-bg-border pt-8">
      <div class="grid grid-cols-2 gap-4">
        <div class="col-start-1">
          {prev && (
            <a
              href={`/projects/${prev.id}`}
              class="group flex flex-col gap-1 rounded-sm"
            >
              <span class="font-mono text-xs text-fg-secondary">← Previous</span>
              <span class="font-sans text-fg-secondary text-sm group-hover:text-accent transition-colors duration-150 line-clamp-1">
                {prev.data.title}
              </span>
            </a>
          )}
        </div>
        <div class="col-start-2 text-right">
          {next && (
            <a
              href={`/projects/${next.id}`}
              class="group flex flex-col gap-1 items-end rounded-sm"
            >
              <span class="font-mono text-xs text-fg-secondary">Next →</span>
              <span class="font-sans text-fg-secondary text-sm group-hover:text-accent transition-colors duration-150 line-clamp-1">
                {next.data.title}
              </span>
            </a>
          )}
        </div>
      </div>
    </nav>

  </div>
</BaseLayout>

<style>
  /* Markdown prose styles scoped to this page */
  .prose-content :global(h2) {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 1.25rem;
    color: #E8F4F4;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-content :global(h3) {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    color: #E8F4F4;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-content :global(p) {
    font-family: 'Inter', sans-serif;
    color: #9BB3B8;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-content :global(ul), .prose-content :global(ol) {
    color: #9BB3B8;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1.75;
  }
  .prose-content :global(li) {
    font-family: 'Inter', sans-serif;
    margin-bottom: 0.25rem;
  }
  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
  }
  .prose-content :global(th) {
    text-align: left;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #16222C;
    color: #E8F4F4;
    font-weight: 500;
  }
  .prose-content :global(td) {
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #16222C;
    color: #9BB3B8;
  }
  .prose-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    color: #3FE0C5;
    background: #0F1A22;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }
  .prose-content :global(hr) {
    border-color: #16222C;
    margin: 2rem 0;
  }
  .prose-content :global(em) {
    color: #9BB3B8;
    font-style: italic;
  }
</style>
