---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import SkillGroup from '../components/SkillGroup.astro';
import { getCollection, getEntry, render } from 'astro:content';

const aboutEntries = await getCollection('about');
const aboutEntry   = aboutEntries[0];
if (!aboutEntry) throw new Error('about.md not found');

const { photo, education, experience, skills, awards } = aboutEntry.data;
const { Content } = await render(aboutEntry);

const site  = await getEntry('site', 'config');
const { name, email, github, linkedin, scholar, cv } = site!.data;
---

<BaseLayout
  title={`About — ${name}`}
  description={`Learn more about ${name} — AI researcher in computer vision and graphics.`}
>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 py-12 md:py-20">

    <!-- Page heading -->
    <h1 class="font-heading font-bold text-fg-primary text-3xl md:text-4xl lg:text-5xl mb-12">
      About
    </h1>

    <!-- Bio -->
    <section class="mb-16" aria-labelledby="bio-heading">
      <h2 id="bio-heading" class="sr-only">Bio</h2>
      <div class="flex flex-col md:flex-row gap-8 items-start">
        {photo && (
          <img
            src={photo}
            alt={`Photo of ${name}`}
            width="160"
            height="160"
            class="rounded-full w-32 h-32 md:w-40 md:h-40 object-cover border-2 border-bg-border shrink-0"
          />
        )}
        <div class="prose-about font-sans text-fg-secondary leading-relaxed space-y-4">
          <Content />
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="mb-16" aria-labelledby="education-heading">
      <h2 id="education-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl mb-8">
        Education
      </h2>
      <Timeline items={education} type="education" />
    </section>

    <!-- Experience -->
    <section class="mb-16" aria-labelledby="experience-heading">
      <h2 id="experience-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl mb-8">
        Experience
      </h2>
      <Timeline items={experience} type="experience" />
    </section>

    <!-- Skills -->
    <section class="mb-16" aria-labelledby="skills-heading">
      <h2 id="skills-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl mb-8">
        Skills
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {Object.entries(skills).map(([label, items]) => (
          <SkillGroup label={label} skills={items} />
        ))}
      </div>
    </section>

    <!-- Awards -->
    {awards && awards.length > 0 && (
      <section class="mb-16" aria-labelledby="awards-heading">
        <h2 id="awards-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl mb-8">
          Awards
        </h2>
        <ul class="space-y-3 list-none m-0 p-0">
          {awards.map(award => (
            <li class="flex gap-3 font-sans text-fg-secondary text-sm md:text-base">
              <span class="text-accent shrink-0 mt-0.5" aria-hidden="true">★</span>
              {award}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Contact + CV -->
    <section aria-labelledby="contact-heading" class="border-t border-bg-border pt-10">
      <h2 id="contact-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl mb-6">
        Get in Touch
      </h2>
      <div class="flex flex-wrap gap-4 items-center">
        <a
          href={cv}
          download
          class="inline-flex items-center justify-center min-h-[44px] px-6 py-2.5 bg-accent text-bg-base font-sans font-medium text-sm rounded hover:bg-accent-light transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
        >
          Download CV
        </a>
        <a
          href={`mailto:${email}`}
          class="inline-flex items-center justify-center min-h-[44px] px-6 py-2.5 border border-bg-border text-fg-secondary font-sans text-sm rounded hover:border-accent hover:text-accent transition-all duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
        >
          {email}
        </a>
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center min-h-[44px] px-4 py-2 text-fg-tertiary hover:text-accent transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
          aria-label="GitHub"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center min-h-[44px] px-4 py-2 text-fg-tertiary hover:text-accent transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
          aria-label="LinkedIn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .prose-about :global(p) {
    color: #9BB3B8;
    font-size: 1rem;
    line-height: 1.75;
  }
  .prose-about :global(em) {
    color: #5A6F75;
  }
</style>
