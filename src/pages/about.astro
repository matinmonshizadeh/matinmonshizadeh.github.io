---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/shared/SectionHeading.astro';
import TimelineEntry from '../components/shared/TimelineEntry.astro';
import SkillGroup from '../components/shared/SkillGroup.astro';
import { getCollection, getEntry, render } from 'astro:content';

const aboutEntries = await getCollection('about');
const aboutEntry   = aboutEntries[0];
if (!aboutEntry) throw new Error('about.md not found');

const { professional_summary, technical_skills, education } = aboutEntry.data;
const { Content } = await render(aboutEntry);

const site = await getEntry('site', 'config');
const { name, role } = site!.data;
---

<BaseLayout
  title={`About — ${name}`}
  description={`Learn more about ${name} — ${role}.`}
>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 py-12 md:py-20 lg:py-28">

    <h1 class="font-heading font-bold text-fg-primary text-3xl md:text-4xl lg:text-5xl mb-16">
      About
    </h1>

    <!-- Section 1: Professional Summary -->
    <section class="mb-16" aria-labelledby="summary-heading">
      <SectionHeading heading={professional_summary.heading} id="summary-heading" />
      <div class="flex flex-col md:flex-row gap-8 items-start" data-animate>
        {professional_summary.photo && (
          <img
            src={professional_summary.photo}
            alt={professional_summary.photo_alt ?? `Photo of ${name}`}
            width="160"
            height="160"
            class="rounded-full w-32 h-32 md:w-40 md:h-40 object-cover border-2 border-bg-border shrink-0"
          />
        )}
        <div class="prose-about font-sans text-fg-secondary leading-relaxed space-y-4">
          <Content />
        </div>
      </div>
    </section>

    <!-- Section 2: Technical Skills -->
    <section class="mb-16" aria-labelledby="skills-heading">
      <SectionHeading heading={technical_skills.heading} id="skills-heading" />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8" data-animate>
        {technical_skills.groups.map(group => (
          <SkillGroup name={group.name} skills={group.skills} />
        ))}
      </div>
    </section>

    <!-- Section 3: Education -->
    <section class="mb-16" aria-labelledby="education-heading">
      <SectionHeading heading={education.heading} id="education-heading" />
      <ol class="relative border-l border-bg-border ml-3 space-y-8 list-none m-0 p-0" data-animate>
        {education.entries.map(entry => (
          <TimelineEntry
            title={entry.degree}
            subtitle={entry.institution}
            location={entry.location}
            start_date={entry.start_date}
            end_date={entry.end_date}
            description={entry.description}
            logo={entry.logo}
          />
        ))}
      </ol>
    </section>

  </div>
</BaseLayout>

<style>
  .prose-about :global(p) {
    color: var(--color-fg-secondary);
    font-size: 1rem;
    line-height: 1.75;
  }
  .prose-about :global(em) {
    color: var(--color-fg-secondary);
  }
</style>
