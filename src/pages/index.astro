---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import LivingForestHero from '../components/hero/LivingForestHero.astro';
import GetInTouchSection from '../components/home/GetInTouchSection.astro';
import { getEntry, getCollection } from 'astro:content';

const site     = await getEntry('site', 'config');
const { name, tagline, intro } = site!.data;

const allProjects = await getCollection('projects');
const featured    = allProjects.filter(p => p.data.featured);
---

<BaseLayout title={name} description={tagline}>

  <!-- ── Hero ── -->
  <LivingForestHero />

  <!-- ── Intro strip ── -->
  <section
    class="py-12 md:py-20 border-t border-bg-border"
    aria-labelledby="intro-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24">
      <div class="max-w-2xl mx-auto text-center" data-animate>
        <h2 id="intro-heading" class="sr-only">About me</h2>
        <p class="font-sans text-fg-secondary text-base md:text-lg leading-relaxed">
          {intro}
        </p>
      </div>
    </div>
  </section>

  <!-- ── Featured projects ── -->
  {featured.length > 0 && (
    <section
      class="py-12 md:py-20 border-t border-bg-border"
      aria-labelledby="featured-heading"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24">
        <div class="flex items-end justify-between mb-8 md:mb-10" data-animate>
          <h2 id="featured-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl lg:text-4xl">
            Featured Projects
          </h2>
          <a
            href="/projects"
            class="font-sans text-accent text-sm hover:text-accent-light transition-colors duration-150 whitespace-nowrap ml-4"
          >
            See all →
          </a>
        </div>
        <ProjectGrid projects={featured} />
      </div>
    </section>
  )}

  <!-- ── Get in Touch ── -->
  <GetInTouchSection />

</BaseLayout>
