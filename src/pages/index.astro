---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import ShaderCanvas from '../components/ShaderCanvas';
import { getEntry, getCollection } from 'astro:content';

const site     = await getEntry('site', 'config');
const { name, role, tagline, intro, cv } = site!.data;

const allProjects = await getCollection('projects');
const featured    = allProjects.filter(p => p.data.featured);
---

<BaseLayout title={name} description={tagline}>

  <!-- ── Hero ── -->
  <section
    class="relative min-h-[calc(100vh-4rem)] flex items-center hero-radial overflow-hidden"
    aria-label="Introduction"
  >
    <!-- WebGL canvas — desktop & tablet (≥768px). The component itself also
         guards against <768px and prefers-reduced-motion internally. -->
    <div class="absolute inset-0 hidden md:block" aria-hidden="true">
      <ShaderCanvas client:load />
    </div>

    <!-- Static CSS fallback — shown on mobile (<768px) or when JS is off -->
    <div class="absolute inset-0 md:hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 right-1/4 w-56 h-56 rounded-full bg-accent/5 blur-3xl"></div>
      <div class="absolute bottom-1/3 right-1/6 w-40 h-40 rounded-full bg-mist/10 blur-2xl"></div>
    </div>

    <!-- Text content — always above canvas -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 py-12 md:py-20 lg:py-28 w-full">
      <div class="max-w-2xl">
        <p class="font-mono text-accent text-sm mb-4 tracking-wide">
          {role}
        </p>

        <h1 class="font-heading font-bold text-fg-primary text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-tight mb-6">
          {name}
        </h1>

        <p class="font-sans text-fg-secondary text-lg md:text-xl max-w-xl mb-10 leading-relaxed">
          {tagline}
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="/projects"
            class="inline-flex items-center justify-center min-h-[44px] px-6 py-2.5 bg-accent text-bg-base font-sans font-medium text-sm rounded hover:bg-accent-light hover:shadow-[0_0_20px_rgba(63,224,197,0.4)] transition-all duration-150"
          >
            View Projects
          </a>
          <a
            href={cv}
            download
            class="inline-flex items-center justify-center min-h-[44px] px-6 py-2.5 border border-accent text-accent font-sans font-medium text-sm rounded hover:bg-accent hover:text-bg-base hover:shadow-[0_0_20px_rgba(63,224,197,0.3)] transition-all duration-150"
          >
            Download CV
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Intro strip ── -->
  <section
    class="py-12 md:py-20 border-t border-bg-border"
    aria-labelledby="intro-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24">
      <div class="max-w-2xl mx-auto text-center" data-animate>
        <h2 id="intro-heading" class="sr-only">About me</h2>
        <p class="font-sans text-fg-secondary text-base md:text-lg leading-relaxed">
          {intro}
        </p>
      </div>
    </div>
  </section>

  <!-- ── Featured projects ── -->
  {featured.length > 0 && (
    <section
      class="py-12 md:py-20 border-t border-bg-border"
      aria-labelledby="featured-heading"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24">
        <div class="flex items-end justify-between mb-8 md:mb-10" data-animate>
          <h2 id="featured-heading" class="font-heading font-semibold text-fg-primary text-2xl md:text-3xl lg:text-4xl">
            Featured Projects
          </h2>
          <a
            href="/projects"
            class="font-sans text-accent text-sm hover:text-accent-light transition-colors duration-150 whitespace-nowrap ml-4"
          >
            See all →
          </a>
        </div>
        <ProjectGrid projects={featured} />
      </div>
    </section>
  )}

</BaseLayout>
