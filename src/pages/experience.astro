---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const site = await getEntry('site', 'config');
const { name } = site!.data;
---

<BaseLayout title={`Experience — ${name}`} description="Work experience and professional background.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 py-12 md:py-20 lg:py-28">
    <h1 class="font-heading font-bold text-fg-primary text-3xl md:text-4xl lg:text-5xl mb-4">
      Experience
    </h1>
    <p class="font-sans text-fg-tertiary text-base">Coming soon.</p>
  </div>
</BaseLayout>
