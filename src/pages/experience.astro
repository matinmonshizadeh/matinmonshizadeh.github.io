---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/shared/SectionHeading.astro';
import TimelineEntry from '../components/shared/TimelineEntry.astro';
import { getCollection, getEntry } from 'astro:content';

const expEntries = await getCollection('experience');
const expEntry   = expEntries[0];
if (!expEntry) throw new Error('experience.md not found');

const { work_history, volunteering, cv } = expEntry.data;

const site = await getEntry('site', 'config');
const { name } = site!.data;
---

<BaseLayout
  title={`Experience — ${name}`}
  description={`Work history, volunteering, and CV for ${name}.`}
>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 md:px-12 lg:px-24 py-12 md:py-20 lg:py-28">

    <h1 class="font-heading font-bold text-fg-primary text-3xl md:text-4xl lg:text-5xl mb-16">
      Experience
    </h1>

    <!-- Section 1: Work History -->
    <section class="mb-16" aria-labelledby="work-heading">
      <SectionHeading heading={work_history.heading} />
      {work_history.entries.length > 0 ? (
        <ol class="relative border-l border-bg-border ml-3 space-y-8 list-none m-0 p-0" data-animate>
          {work_history.entries.map(entry => (
            <TimelineEntry
              title={entry.role}
              subtitle={entry.company}
              location={entry.location}
              start_date={entry.start_date}
              end_date={entry.end_date}
              description={entry.description}
              bullets={entry.bullets}
              logo={entry.logo}
            />
          ))}
        </ol>
      ) : (
        <p class="font-sans text-fg-tertiary text-sm">No entries yet.</p>
      )}
    </section>

    <!-- Section 2: Volunteering -->
    <section class="mb-16" aria-labelledby="volunteering-heading">
      <SectionHeading heading={volunteering.heading} />
      {volunteering.entries.length > 0 ? (
        <ol class="relative border-l border-bg-border ml-3 space-y-8 list-none m-0 p-0" data-animate>
          {volunteering.entries.map(entry => (
            <TimelineEntry
              title={entry.role}
              subtitle={entry.organization}
              location={entry.location}
              start_date={entry.start_date}
              end_date={entry.end_date}
              description={entry.description}
              bullets={entry.bullets}
              logo={entry.logo}
            />
          ))}
        </ol>
      ) : (
        <p class="font-sans text-fg-tertiary text-sm">No entries yet.</p>
      )}
    </section>

    <!-- Section 3: CV Download -->
    <section aria-labelledby="cv-heading" class="border-t border-bg-border pt-10">
      <SectionHeading heading={cv.heading} />
      <p class="font-sans text-fg-secondary text-base mb-6">{cv.intro}</p>
      <a
        href={cv.file}
        download
        class="inline-flex items-center justify-center min-h-[44px] px-8 py-3 bg-accent text-bg-base font-sans font-semibold text-sm rounded hover:bg-accent-light hover:shadow-[0_0_20px_rgba(63,224,197,0.4)] focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-base transition-all duration-150"
      >
        {cv.button_label}
      </a>
    </section>

  </div>
</BaseLayout>
