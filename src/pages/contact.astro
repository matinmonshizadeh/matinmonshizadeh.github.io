---
import BaseLayout from '../layouts/BaseLayout.astro';
import PatronusScene from '../components/contact/PatronusScene';
import { getEntry } from 'astro:content';
import patronusSrc   from '../assets/hero/patronus.png';
import letterSrc     from '../assets/hero/magical-letter.png';

const site = await getEntry('site', 'config');
const { name, github, linkedin, email, location, contact_page_meta_desc } = site!.data;
---

<BaseLayout title={`Contact — ${name}`} description={contact_page_meta_desc ?? 'Cast a spell to reveal my contact details.'}>
  <PatronusScene
    client:load
    patronusSrc={patronusSrc.src}
    letterSrc={letterSrc.src}
    github={github}
    linkedin={linkedin}
    email={email}
    name={name}
    location={location}
  />
</BaseLayout>
